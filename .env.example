# Application environment (REQUIRED — no default!)
# Valid values: development, test, qa, production
APP_ENVIRONMENT=development

# JWT signing secret (minimum 32 characters!)
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Database (defaults to SQLite if not set)
# DATABASE_URL=sqlite:////database/legacy_db.sqlite3

# Session configuration
SESSION_LIFETIME_MINUTES=15
SESSION_IDLE_TIMEOUT_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# Password policy
PASSWORD_MIN_LENGTH=8

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SMTP (Email)
SMTP_HOST=mailpit.dev.schimpl.cc
SMTP_PORT=1025
SMTP_USER=null
SMTP_PASSWORD=null
SMTP_FROM_EMAIL=noreply@vindobona.at
SMTP_FROM_NAME=VB intern

# Frontend URL for password reset links
FRONTEND_RESET_URL=https://app.vb-intern.dev.schimpl.cc/auth/reset-password

# S3 path prefixes within the bucket (optional — shown with defaults)
# S3_PATH_STANDESDB_IMAGES=standesdb/images
# S3_PATH_STANDESDB_CACHE=standesdb/cache
# S3_PATH_ARCHIVE_STORE=archive/store
# S3_PATH_ARCHIVE_CACHE=archive/cache
# S3_PATH_DB_BACKUPS=db-backups

# DB backup schedule (optional, defaults shown — adjust per environment)
# Set BACKUP_ENABLED=false to disable scheduled backups entirely (e.g. in dev/test/qa)
# BACKUP_ENABLED=true
# BACKUP_INTERVAL_DAYS=7
# BACKUP_HOUR=3
# Days to keep DB backups in S3 before automatic deletion
# BACKUP_RETENTION_DAYS=90
