# =============================================================================
# Vindobona NG — Backend (vb-api) Environment Configuration
# =============================================================================
# DE: Kopiere diese Datei zu ".env" und passe die Werte für deine Umgebung an.
#     Variablen ohne "#" davor sind verpflichtend — die App startet ohne sie
#     gar nicht erst (Fail-Fast). Auskommentierte Variablen sind optional,
#     der gezeigte Wert ist der Code-Default.
# EN: Copy this file to ".env" and adjust the values for your environment.
#     Variables without a leading "#" are required — the app refuses to
#     start without them (fail-fast). Commented-out variables are optional,
#     the shown value is the code's default.
#
# DE: Die echte Env-Datei liegt NICHT in diesem Repo, sondern wird vom
#     jeweiligen Zielsystem bereitgestellt — wie genau, hängt vom
#     Deployment-Ziel ab (z. B. Environment-Variablen im Dashboard eines
#     Serverless-Anbieters wie Railway). Aktuell (Podman/Quadlets-Setup)
#     liegt sie unter "~/.env/vb-api.env" und wird über das Quadlet
#     "vb-api.container" eingebunden (Zeile
#     "EnvironmentFile=%h/.env/vb-api.env", %h = Home-Verzeichnis des
#     Service-Users). Siehe ~/.config/containers/systemd/vb/api/vb-api.container.
# EN: The real env file does NOT live in this repo — it is provided by
#     whatever target system runs the app. The exact mechanism depends on
#     the deployment target (e.g. environment variables in a serverless
#     provider's dashboard such as Railway). Currently (Podman/Quadlets
#     setup) it lives at "~/.env/vb-api.env" and is loaded via the
#     Quadlet unit "vb-api.container" (line
#     "EnvironmentFile=%h/.env/vb-api.env", %h = service user's home
#     directory). See ~/.config/containers/systemd/vb/api/vb-api.container.
# =============================================================================

# ===== Core / Environment =====

# DE: Steuert umgebungsspezifisches Verhalten (z. B. Dev-Login, Backup-Defaults).
#     Erlaubte Werte: development, test, qa, production. Pflichtfeld ohne
#     Default — fehlt sie, startet die App nicht.
# EN: Controls environment-specific behavior (e.g. dev login, backup
#     defaults). Allowed values: development, test, qa, production.
#     Required, no default — the app won't start without it.
APP_ENVIRONMENT=development

# DE: Geheimer Schlüssel zum Signieren der JWT-Access-/Refresh-Tokens.
#     Muss mindestens 32 Zeichen lang sein (Validierung beim Start), sonst
#     bricht der App-Start ab. Pro Umgebung einen eigenen, zufälligen Wert
#     verwenden — niemals den Beispielwert in Produktion übernehmen.
# EN: Secret key used to sign JWT access/refresh tokens. Must be at least
#     32 characters (validated on startup) or the app refuses to start.
#     Use a unique random value per environment — never reuse the example
#     value in production.
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ===== Database =====

# DE: Verbindungsstring zur Datenbank (PostgreSQL empfohlen, z. B.
#     "postgresql+asyncpg://user:pass@host:5432/dbname"). Fehlt die
#     Variable, fällt der Code auf eine lokale SQLite-Datei zurück — das
#     ist ein Legacy-Fallback aus der Migrationsphase und nicht für den
#     Produktivbetrieb gedacht.
# EN: Database connection string (PostgreSQL recommended, e.g.
#     "postgresql+asyncpg://user:pass@host:5432/dbname"). If unset, the
#     code falls back to a local SQLite file — this is a legacy fallback
#     from the migration phase and not intended for production use.
# DATABASE_URL=sqlite:////database/legacy_db.sqlite3

# ===== Session / Auth =====

# DE: Gültigkeitsdauer eines Access-Tokens in Minuten.
# EN: Validity period of an access token, in minutes.
SESSION_LIFETIME_MINUTES=15

# DE: Nach so vielen Minuten Inaktivität wird die Session als abgelaufen
#     behandelt, auch wenn der Access-Token technisch noch gültig wäre.
# EN: After this many minutes of inactivity, the session is treated as
#     expired even if the access token would technically still be valid.
SESSION_IDLE_TIMEOUT_MINUTES=30

# DE: Gültigkeitsdauer eines Refresh-Tokens in Tagen (damit kann ein
#     Nutzer ohne erneuten Login einen neuen Access-Token bekommen).
# EN: Validity period of a refresh token, in days (lets a user obtain a
#     new access token without logging in again).
REFRESH_TOKEN_LIFETIME_DAYS=7

# DE: Mindestlänge für neue/zurückgesetzte Passwörter (Backend-Validierung).
#     Sollte mit VITE_PASSWORD_MIN_LENGTH im Frontend übereinstimmen —
#     wird nicht automatisch synchronisiert, manuell pflegen!
# EN: Minimum length for new/reset passwords (backend-side validation).
#     Should match VITE_PASSWORD_MIN_LENGTH in the frontend — not
#     auto-synced, keep both in sync manually!
PASSWORD_MIN_LENGTH=8

# ===== OAuth2 (Google) =====

# DE: Client-ID der Google-OAuth2-App für den "Mit Google anmelden"-Login.
#     Muss mit dem Wert in VITE_GOOGLE_CLIENT_ID (Frontend) übereinstimmen,
#     da beide dieselbe Google-Cloud-App referenzieren.
# EN: Client ID of the Google OAuth2 app used for "Sign in with Google".
#     Must match the value in VITE_GOOGLE_CLIENT_ID (frontend), since both
#     reference the same Google Cloud app.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ===== SMTP / E-Mail =====

# DE: Hostname des SMTP-Servers für ausgehende E-Mails (Passwort-Reset,
#     Geburtstagsmails, Berichte etc.). Pflichtfeld.
# EN: Hostname of the SMTP server for outgoing emails (password reset,
#     birthday mails, reports, etc.). Required.
SMTP_HOST=mailpit.dev.schimpl.cc

# DE: Port des SMTP-Servers. Pflichtfeld.
# EN: Port of the SMTP server. Required.
SMTP_PORT=1025

# DE: SMTP-Zugangsdaten. Der String "null" (wörtlich!) bedeutet "kein
#     Login nötig" — praktisch für lokale Testserver wie Mailpit, die
#     ohne Authentifizierung laufen.
# EN: SMTP credentials. The literal string "null" means "no login
#     needed" — useful for local test servers like Mailpit that run
#     without authentication.
SMTP_USER=null
SMTP_PASSWORD=null

# DE: Absenderadresse im "From"-Header aller ausgehenden Mails. Pflichtfeld.
# EN: Sender address in the "From" header of all outgoing mails. Required.
SMTP_FROM_EMAIL=noreply@vindobona.at

# DE: Anzeigename im "From"-Header (optional, hat einen sinnvollen Default).
# EN: Display name in the "From" header (optional, has a sensible default).
SMTP_FROM_NAME=VB intern

# DE: Basis-URL des Frontends, die in Passwort-Reset-Mails als Link
#     eingebettet wird (z. B. ".../auth/reset-password?token=..."). Pflichtfeld.
# EN: Base URL of the frontend, embedded as a link in password-reset
#     emails (e.g. ".../auth/reset-password?token=..."). Required.
FRONTEND_RESET_URL=https://app.vb-intern.dev.schimpl.cc/auth/reset-password

# ===== S3 / Object Storage =====
# DE: Speichert Archiv-Dateien, Standesdb-Bilder und DB-Backups. Kompatibel
#     zu AWS S3 und S3-kompatiblen Servern wie MinIO (lokale Entwicklung).
# EN: Stores archive files, registry images, and DB backups. Compatible
#     with AWS S3 and S3-compatible servers like MinIO (local development).

# DE: Endpoint-URL des S3-Dients. Für echtes AWS S3 weglassen/Standard-
#     Endpoint nutzen; für MinIO die lokale/interne URL angeben.
# EN: Endpoint URL of the S3 service. Leave at the AWS default for real
#     AWS S3; point to the local/internal URL for MinIO.
# S3_ENDPOINT_URL=http://localhost:9000

# DE: Zugangsschlüssel für den S3-Dienst. Niemals echte Produktiv-Keys
#     hier oder in dieser Datei committen.
# EN: Access credentials for the S3 service. Never commit real production
#     keys here or in this file.
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# DE: Name des S3-Buckets, in dem alle Anwendungsdaten liegen.
# EN: Name of the S3 bucket holding all application data.
# S3_BUCKET=vb-intern

# DE: Öffentlich erreichbare Endpoint-URL, die in Presigned URLs (Links
#     zum direkten Datei-Download fürs Frontend) eingebettet wird. Fällt
#     auf S3_ENDPOINT_URL zurück, falls nicht gesetzt — nur nötig, wenn
#     der interne und der öffentlich erreichbare S3-Host unterschiedlich sind.
# EN: Publicly reachable endpoint URL embedded in presigned URLs (direct
#     file-download links for the frontend). Falls back to
#     S3_ENDPOINT_URL when unset — only needed if the internal and the
#     publicly reachable S3 host differ.
# S3_PUBLIC_ENDPOINT_URL=

# DE: AWS-Region des Buckets (bei MinIO eine beliebige Pseudo-Region).
# EN: AWS region of the bucket (any pseudo-region works for MinIO).
# S3_REGION=us-east-1

# DE: Gültigkeitsdauer generierter Presigned URLs in Sekunden (erlaubter
#     Bereich: 60–86400, also 1 Minute bis 24 Stunden).
# EN: Validity period of generated presigned URLs, in seconds (allowed
#     range: 60–86400, i.e. 1 minute to 24 hours).
# S3_PRESIGNED_EXPIRY=900

# DE: Pfad-Präfixe innerhalb des Buckets, um die Datenbereiche logisch
#     zu trennen. Nur ändern, wenn bewusst eine andere Bucket-Struktur
#     gewünscht ist — bestehende Daten liegen sonst am falschen Pfad.
# EN: Path prefixes within the bucket to logically separate data areas.
#     Only change if a different bucket layout is intentional — existing
#     data would otherwise end up under the wrong path.
# S3_PATH_STANDESDB_IMAGES=standesdb/images
# S3_PATH_STANDESDB_CACHE=standesdb/cache
# S3_PATH_ARCHIVE_STORE=archive/store
# S3_PATH_ARCHIVE_CACHE=archive/cache
# S3_PATH_DB_BACKUPS=db-backups

# ===== DB-Backup-Zeitplan =====

# DE: Schaltet die automatischen, geplanten DB-Backups (nach S3) ein/aus.
#     In Dev/Test/QA meist auf false sinnvoll, um Rauschen zu vermeiden.
# EN: Enables/disables the automatic, scheduled DB backups (to S3).
#     Usually set to false in dev/test/qa to reduce noise.
# BACKUP_ENABLED=true

# DE: Intervall zwischen zwei Backups in Tagen.
# EN: Interval between two backups, in days.
# BACKUP_INTERVAL_DAYS=7

# DE: Tagesstunde (0–23, UTC), zu der das Backup läuft.
# EN: Hour of day (0–23, UTC) at which the backup job runs.
# BACKUP_HOUR=3

# DE: Anzahl Tage, die ein DB-Backup in S3 aufbewahrt wird, bevor es
#     automatisch gelöscht wird.
# EN: Number of days a DB backup is retained in S3 before it gets
#     automatically deleted.
# BACKUP_RETENTION_DAYS=90

# ===== Tracking =====

# DE: Anzahl Monate, die Request-Tracking-Logs (Audit-Trail von API-
#     Zugriffen) aufbewahrt werden, bevor sie aufgeräumt werden.
# EN: Number of months request-tracking logs (audit trail of API access)
#     are retained before being cleaned up.
# TRACKING_RETENTION_MONTHS=6

# ===== Dev-only =====

# DE: NUR für lokale Entwicklung. Member-ID, der beim Login automatisch
#     Superuser-Rechte zugewiesen werden, um sich Klick-Arbeit zu sparen.
#     Wird außerhalb von APP_ENVIRONMENT=development ignoriert — in
#     Produktion daher wirkungslos und unbedenklich, wenn versehentlich
#     gesetzt. Trotzdem: in echten Umgebungen unbedingt weglassen.
# EN: LOCAL DEVELOPMENT ONLY. Member ID that is automatically granted
#     superuser rights on login, to save manual clicking. Ignored outside
#     of APP_ENVIRONMENT=development — harmless if accidentally set in
#     production. Still, leave it unset in real environments.
# DEV_SUPERUSER_ID=0
